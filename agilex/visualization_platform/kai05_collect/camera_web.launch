<launch>

  <!-- ========================= -->
  <!-- 1️⃣ 启动多路 RealSense -->
  <!-- ========================= -->
  <include file="$(find realsense2_camera)/launch/multi_camera2.launch" />

  <!-- ========================= -->
  <!-- 2️⃣ 启动 web_video_server -->
  <!-- ========================= -->
  <node
      pkg="web_video_server"
      type="web_video_server"
      name="web_video_server"
      output="screen">

    <!-- 可选：端口 -->
    <param name="port" value="8080" />

    <!-- 可选：JPEG 压缩质量 -->
    <param name="quality" value="80" />
  </node>

</launch>
